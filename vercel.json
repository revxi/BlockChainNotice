{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "blockchain/backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "blockchain/backend/server.js"
    },
    {
      "src": "/",
      "dest": "blockchain/backend/server.js"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
